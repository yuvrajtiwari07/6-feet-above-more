rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSystemAdmin() {
      return isSignedIn() 
        && request.auth.token.email_verified == true 
        && (request.auth.token.email == 'ytiwari@argusoft.com' || request.auth.token.email == 'yuvrajtiwari0710@gmail.com');
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Robust User Profile Schema Validator (Pillar 2)
    function isValidUserProfile(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && (!("height" in data) || (data.height is string && data.height.size() <= 10))
        && (!("bodyType" in data) || (data.bodyType is string && data.bodyType.size() <= 15))
        && (!("cardSize" in data) || (data.cardSize == 'small' || data.cardSize == 'medium' || data.cardSize == 'large'))
        && (!("savedProductIds" in data) || (data.savedProductIds is list))
        && (!("savedFitIds" in data) || (data.savedFitIds is list))
        && (!("preferences" in data) || (data.preferences is map));
    }

    // Robust Product Schema Validator
    function isValidProduct(data) {
      return data.id is string
        && data.brand is string
        && data.brand.size() <= 100
        && data.title is string
        && data.title.size() <= 200
        && data.category is string
        && data.priceAtRetailer is number;
    }
    
    // User Profile Document Security
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // Products collection security: anyone can read, only admins can create/update/delete
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isSystemAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow delete: if isSystemAdmin() && isValidId(productId);
    }
  }
}
